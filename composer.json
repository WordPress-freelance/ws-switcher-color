{
    "name": "webstrategy/ws-switcher-color",
    "description": "Dark / light switcher for Avada by remapping CSS variables.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "WebStrategy",
            "homepage": "https://wordpress-freelance.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^0.5",
        "mockery/mockery": "^1.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "WS_Switcher_Color\\Tests\\Unit\\": "tests/unit/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "test:integration": "phpunit -c phpunit-integration.xml"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
